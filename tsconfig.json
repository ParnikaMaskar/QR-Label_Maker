{
  "files": [],
  "references": [{ "path": "./tsconfig.app.json" }, { "path": "./tsconfig.node.json" }],
  "compilerOptions": {
     "lib": ["DOM", "DOM.Iterable", "ESNext"],
     "types": [],
    "baseUrl": ".",
